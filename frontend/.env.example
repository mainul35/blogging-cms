# Copy to .env.local and adjust. All values below are optional — sensible
# defaults are baked in, so the app runs out of the box without this file.

# Site name is no longer set here — it's a database-backed setting, editable
# from the admin Settings page (defaults to "Blog CMS" until changed there).

# Backend API origin, reachable from the browser.
NEXT_PUBLIC_BACKEND_URL=http://localhost:8080

# Backend API origin, reachable from the Next.js server (used by next.config.js's
# /api/backend/* rewrite). Usually the same value as above.
BACKEND_URL=http://localhost:8080

# --- Reader sign-in (Google/GitHub OAuth for comments, mentions, newsletter) ---
# Required to enable reader sign-in. Register OAuth apps with redirect URIs:
#   http://localhost:3000/api/reader-auth/callback/google
#   http://localhost:3000/api/reader-auth/callback/github
# (note the non-default /api/reader-auth path -- not /api/auth)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# NextAuth's own session-signing secret. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Must exactly match the backend's app.internal.auth-secret / INTERNAL_AUTH_SECRET.
INTERNAL_AUTH_SECRET=change-this-internal-secret
